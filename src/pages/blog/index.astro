---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Writing — Madhav Gupta">
  <div class="container">
    <header class="page-head">
      <p class="mono kicker">05. Writing</p>
      <h1>Blog</h1>
      <p class="lead">
        Occasional notes on machine learning, research, and whatever else seems worth
        writing down.
      </p>
    </header>

    <div class="post-list">
      {
        posts.map((post) => (
          <a class="post reveal" href={`/blog/${post.id}/`}>
            <div class="post-date mono">{post.data.date.toISOString().slice(0, 10)}</div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </a>
        ))
      }
    </div>

    <p class="back"><a class="mono" href="/">← Back home</a></p>
  </div>
</Base>

<style>
  .page-head {
    max-width: 680px;
    padding: var(--space-xl) 0 var(--space-xxl);
  }

  .kicker {
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }

  h1 {
    font-size: clamp(32px, 5vw, 44px);
    font-weight: 700;
  }

  .lead {
    color: var(--muted);
    margin-top: var(--space-md);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 680px;
  }

  .post {
    display: block;
    padding: var(--space-lg);
    margin: 0 calc(-1 * var(--space-lg));
    border-radius: var(--rounded-md);
    color: inherit;
    transition: background var(--transition);
  }

  .post:hover {
    background: var(--surface);
    text-decoration: none;
  }

  .post-date {
    color: var(--muted);
    font-size: 0.72rem;
  }

  .post h2 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-top: var(--space-xs);
    transition: color var(--transition);
  }

  .post:hover h2 {
    color: var(--accent);
  }

  .post p {
    color: var(--muted);
    font-size: 0.9rem;
    margin-top: var(--space-sm);
  }

  .back {
    padding: var(--space-xxl) 0;
  }

  .back a {
    font-size: 0.8rem;
  }
</style>
