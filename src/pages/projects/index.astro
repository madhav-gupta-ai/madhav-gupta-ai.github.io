---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import TagFilter from '../../components/TagFilter.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Filter topics = every tag in use, most common first.
const tagCounts = new Map<string, number>();
projects.forEach((p) =>
  p.data.tags.forEach((t) => tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1))
);
const topics = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([t]) => t);
---

<Base title="Projects — Madhav Gupta">
  <div class="container">
    <header class="page-head">
      <p class="mono kicker">04. Projects</p>
      <h1>All Projects</h1>
      <p class="lead">
        Technical projects across speech, healthcare NLP, simulation, and statistics.
        Filter by topic below.
      </p>
    </header>

    <TagFilter tags={topics} />

    <div class="card-grid">
      {
        projects.map((project) => (
          <div class="filter-item" data-tags={project.data.tags.join('|')}>
            <ProjectCard project={project} />
          </div>
        ))
      }
    </div>

    <p class="back"><a class="mono" href="/">← Back home</a></p>
  </div>
</Base>

<style>
  .page-head {
    max-width: 680px;
    padding: var(--space-xl) 0 var(--space-xl);
  }

  .kicker {
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }

  h1 {
    font-size: clamp(32px, 5vw, 44px);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .lead {
    color: var(--muted);
    margin-top: var(--space-md);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .filter-item > :global(.card) {
    height: 100%;
  }

  .filter-item.hidden {
    display: none;
  }

  .filter-item.pop {
    animation: card-in 0.35s ease both;
  }

  @keyframes card-in {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
  }

  .back {
    padding: var(--space-xxl) 0;
  }

  .back a {
    font-size: 0.8rem;
  }

  @media (max-width: 768px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
