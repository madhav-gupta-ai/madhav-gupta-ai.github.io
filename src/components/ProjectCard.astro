---
const { project } = Astro.props;
const d = project.data;
---

<article class="card reveal">
  <div class="card-top">
    <svg class="folder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
    </svg>
  </div>
  <h3><a href={`/projects/${project.id}/`}>{d.title}</a></h3>
  <p>{d.summary}</p>
  <div class="tag-row">
    {d.tags.map((t: string) => <span class="tag">{t}</span>)}
  </div>
  <div class="actions">
    <a class="action mono" href={`/projects/${project.id}/`}>Details →</a>
    {d.github && <a class="action mono" href={d.github} target="_blank" rel="noopener">GitHub ↗</a>}
  </div>
</article>

<style>
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--rounded-md);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    transition: transform var(--transition), border-color var(--transition);
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }

  .card-top {
    margin-bottom: var(--space-md);
  }

  .folder {
    width: 36px;
    height: 36px;
    color: var(--accent);
  }

  .actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .action {
    font-size: 0.7rem;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: var(--rounded-sm);
    padding: 6px 10px;
    transition: color var(--transition), border-color var(--transition);
  }

  .action:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }

  h3 {
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.35;
  }

  h3 a {
    color: var(--heading);
    transition: color var(--transition);
  }

  h3 a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  p {
    color: var(--muted);
    font-size: 0.875rem;
    margin-top: var(--space-sm);
    flex: 1;
  }

  .tag-row {
    margin-top: var(--space-md);
  }
</style>
