---
import { site } from '../data/site';
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { n: '01', label: 'About', href: '/#about' },
  { n: '02', label: 'Experience', href: '/#experience' },
  { n: '03', label: 'Research', href: '/#research' },
  { n: '04', label: 'Projects', href: '/#projects' },
  { n: '05', label: 'Writing', href: '/blog' },
  { n: '06', label: 'Contact', href: '/#contact' },
];
---

<header class="site-nav" id="site-nav">
  <nav class="container nav-inner" aria-label="Primary">
    <a class="logo mono" href="/" aria-label="Home">~/mg</a>

    <!-- mobile-only CTA cluster; display:none on desktop.
         Order: primary CTA → secondary → utility, menu anchored at the edge. -->
    <div class="nav-cta">
      <a class="btn cta-resume" href={site.resume} target="_blank" rel="noopener">Resume</a>
      <a class="cta-contact" href="/#contact" aria-label="Contact">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </a>
      <ThemeToggle />
    </div>

    <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav-menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <div class="nav-menu" id="nav-menu">
      {
        links.map((l) => (
          <a class="nav-link mono" href={l.href}>
            <span class="num">{l.n}.</span> {l.label}
          </a>
        ))
      }
      <a class="btn resume-btn" href={site.resume} target="_blank" rel="noopener">Resume</a>
      <span class="menu-toggle-slot"><ThemeToggle /></span>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('site-nav');
  const toggle = document.querySelector('.nav-toggle');
  const menu = document.getElementById('nav-menu');

  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });

  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      menu.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );

  window.addEventListener(
    'scroll',
    () => header?.classList.toggle('scrolled', window.scrollY > 20),
    { passive: true }
  );
</script>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    background: var(--nav-bg);
    backdrop-filter: blur(10px);
    transition: box-shadow var(--transition);
  }

  .site-nav.scrolled {
    box-shadow: var(--nav-shadow);
  }

  .menu-toggle-slot {
    display: contents;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .logo {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 600;
    transition: transform var(--transition);
  }

  .logo:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }

  .nav-cta {
    display: none;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--accent);
    cursor: pointer;
    padding: var(--space-sm);
  }

  .nav-toggle svg {
    display: block;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav-link {
    color: var(--text);
    font-size: 0.78rem;
    transition: color var(--transition);
  }

  .nav-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .nav-link .num {
    color: var(--accent);
  }

  .resume-btn {
    padding: 10px 16px;
    font-size: 0.78rem;
  }

  @media (max-width: 920px) {
    .nav-toggle {
      display: block;
    }

    .nav-cta {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      margin-left: auto;
      margin-right: var(--space-sm);
    }

    .cta-resume {
      padding: 8px 12px;
      font-size: 0.72rem;
    }

    .cta-contact {
      color: var(--accent);
      display: flex;
      padding: var(--space-sm);
    }

    .cta-contact svg {
      width: 20px;
      height: 20px;
    }

    /* Resume + toggle live in the bar on mobile — hide the duplicates in the menu */
    .nav-menu .resume-btn,
    .menu-toggle-slot {
      display: none;
    }

    .nav-menu {
      display: none;
      position: absolute;
      top: 72px;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: var(--space-lg);
    }

    .nav-menu.open {
      display: flex;
    }
  }

  /* very small phones: tighten the CTA cluster so nothing wraps */
  @media (max-width: 360px) {
    .nav-cta {
      gap: var(--space-sm);
      margin-right: var(--space-xs);
    }

    .cta-resume {
      padding: 6px 10px;
    }

    .cta-contact {
      padding: 6px;
    }
  }
</style>
